[Desktop Entry]
Type=Application
Name=Speech to Text
Comment=Local speech-to-text using Whisper
Exec=%HOME%/.local/share/whisperLocal/whisper2text
Icon=%HOME%/.local/share/whisperLocal/whisper2text.png
Terminal=false
Categories=AudioVideo;Audio;Utility;
StartupNotify=false
X-GNOME-Autostart-enabled=true
